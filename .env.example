# Copy this file to .env and fill in real values before running
# `docker compose up` or starting the backend manually.

# REQUIRED — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Comma-separated list of origins allowed to call the API (no trailing slash)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# The URL the frontend will use to reach the backend (baked in at build time)
PUBLIC_API_BASE=http://localhost:4000

# Backend runtime
NODE_ENV=production
PORT=4000
